{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "sh -c 'npm run next-dev & npm run dev; wait'",
    "next-dev": "next dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "rm -rf .tmp-tests && tsc -p tsconfig.tests.json && node --test --experimental-specifier-resolution=node .tmp-tests/tests/*.test.js && rm -rf .tmp-tests",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "crypto-js": "^4.2.0",
    "lucide-react": "^0.344.0",
    "next": "^16.1.6",
    "pg": "^8.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.7.0",
    "resend": "^6.9.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.2.2"
  }
}
